# Croatian Genealogical Index — Caddy site block
# Place this file in the Caddy conf.d/ directory on your server.
# Replace the domain names to match your environment.

# Frontend — serves the built Vite app
indeks.rodoslovlje.hr {
    root * /var/www/cgi
    file_server
    try_files {path} /index.html
    encode gzip
}

# Backend API — reverse proxy to the Docker container
indeks-api.rodoslovlje.hr {
    reverse_proxy cgi_api:8000
    encode gzip
}
